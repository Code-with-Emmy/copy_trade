# Allow access to images/documents, deny everything else (like logs)
<IfModule mod_authz_core.c>
    Require all denied
    
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|pdf|doc|docx|txt|csv|xls|xlsx)$">
        Require all granted
    </FilesMatch>
    
    # Prevent PHP execution in this folder (Security)
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
</IfModule>

<IfModule !mod_authz_core.c>
    Order Deny,Allow
    Deny from all
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|pdf|doc|docx|txt|csv|xls|xlsx)$">
        Allow from all
    </FilesMatch>
    <FilesMatch "\.php$">
        Deny from all
    </FilesMatch>
</IfModule>
